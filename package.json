{
  "name": "start",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @start/web run dev",
    "dev:full": "pnpm local:up && pnpm dev",
    "coordination-tax:baseline": "node ./scripts/measure-coordination-tax.mjs",
    "local:up": "node ./scripts/local-stack.mjs up",
    "local:down": "node ./scripts/local-stack.mjs down",
    "build": "turbo run build",
    "start": "pnpm --filter @start/web run start",
    "email:dev": "pnpm --filter @start/web run email:dev",
    "lint": "turbo run lint",
    "lint:fix": "pnpm --filter @start/web run lint:fix",
    "test": "turbo run test",
    "test:watch": "pnpm --filter @start/web run test:watch",
    "test:e2e": "pnpm --filter @start/web run test:e2e",
    "test:e2e:ui": "pnpm --filter @start/web run test:e2e:ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "check": "pnpm format:check && pnpm lint && pnpm check-types",
    "pocketbase:typegen": "pnpm --filter @start/web run pocketbase:typegen",
    "pocketbase:mailpit:apply": "node ./scripts/local-stack.mjs apply-mailpit",
    "turbo": "turbo"
  },
  "devDependencies": {
    "prettier": "~3.7.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.9.4"
  }
}
