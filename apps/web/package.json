    "@tanstack/react-form": "^1.28.6",
    "@types/nodemailer": "~7.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
