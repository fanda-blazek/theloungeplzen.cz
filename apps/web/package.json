{
  "name": "@start/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "email:dev": "email dev --dir src/server/email/templates",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node ../../scripts/run-web-e2e.mjs",
    "test:e2e:ui": "node ../../scripts/run-web-e2e.mjs --ui",
    "format": "pnpm --dir ../.. exec prettier --write apps/web",
    "format:check": "pnpm --dir ../.. exec prettier --check apps/web",
    "check-types": "next typegen && tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm check-types",
