# prod env
# Copy values into your production deployment environment.

# email
MAIL_TRANSPORT=smtp # "smtp"/"mailpit-api"
MAIL_HOST=smtp.your-provider.example
MAIL_PORT=465
EMAIL_SECURE=true
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=XYZ
MAIL_FROM_ADDRESS=hello@gtdn.online
MAIL_FROM_NAME="Start App"

# Recipient for all inbound form submissions (Contact, Support, etc.)
GENERAL_FORMS_RECIPIENT=hello@gtdn.online

# Public runtime URLs
NEXT_PUBLIC_APP_URL=https://start.gtdn.online
NEXT_PUBLIC_PB_URL=https://pocketbase-start-prod.up.railway.app

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_ENABLED=true
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAABoTApAdoBJeaARP
TURNSTILE_SECRET_KEY=XYZ

# Cookie consent
NEXT_PUBLIC_COOKIE_CONSENT_ENABLED=true

# third party scripts
NEXT_PUBLIC_GA_ID="G-XYZ"
NEXT_PUBLIC_GTM_ID="GTM-XYZ"
