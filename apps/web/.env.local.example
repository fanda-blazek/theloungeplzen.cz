# local env
# Copy to `.env.local`.
# `pnpm dev` reads this file directly.

# email
MAIL_TRANSPORT=mailpit-api
MAIL_FROM_ADDRESS=hello@gtdn.online
MAIL_FROM_NAME="Start App (Local Dev)"

# Recipient for all inbound form submissions (Contact, Support, etc.)
GENERAL_FORMS_RECIPIENT=hello@gtdn.online

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_ENABLED=true
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAABoTApAdoBJeaARP
TURNSTILE_SECRET_KEY=XYZ

# Cookie consent
NEXT_PUBLIC_COOKIE_CONSENT_ENABLED=true

# local runtime URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PB_URL=http://127.0.0.1:8090
MAILPIT_BASE_URL=http://127.0.0.1:8025

# local PocketBase tooling only (`pnpm pocketbase:typegen`)
PB_SUPERUSER_EMAIL=local-admin@example.com
PB_SUPERUSER_PASSWORD=local-dev-password
