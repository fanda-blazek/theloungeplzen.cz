# testing overrides
# Copy to `.env.test`.
# `pnpm test:e2e` injects isolated local service URLs at runtime.

# email
MAIL_TRANSPORT=mailpit-api
MAIL_FROM_ADDRESS=hello@gtdn.online
MAIL_FROM_NAME="Start App (Test)"

# Recipient for all inbound form submissions (Contact, Support, etc.)
GENERAL_FORMS_RECIPIENT=hello@gtdn.online

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_ENABLED=false
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAABoTApAdoBJeaARP
TURNSTILE_SECRET_KEY=XYZ

# Cookie consent
NEXT_PUBLIC_COOKIE_CONSENT_ENABLED=false

# Mailpit / Playwright
PLAYWRIGHT_TEST_EMAIL=your.name@gmail.com
